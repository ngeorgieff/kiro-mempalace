{
  "name": "MemPalace Auto-Save",
  "version": "1.0.0",
  "description": "Automatically saves session context to MemPalace when the agent stops, mirroring the Claude plugin's Stop hook. Summarizes decisions and writes a diary entry.",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The session is ending. Review the conversation for significant decisions, bug fixes, config changes, architecture choices, or trade-offs discussed. If anything significant happened: 1) Call mempalace_add_drawer with wing set to the workspace basename (lowercase, hyphenated), room set to the appropriate topic (decisions, bugs, config, architecture, etc.), and content set to a concise summary of the key context. 2) Call mempalace_diary_write with agent_name='kiro' and a brief AAAK-format session entry summarizing what was accomplished. If nothing significant happened in this session, skip saving entirely — do not save trivial exchanges."
  }
}
